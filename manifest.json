{
  "manifest_version": 3,
  "name": "Kotiq Translate",
  "version": "0.2.0",
  "description": "Translate selected text on any page, fully on-device — with the browser's built-in translator or a bundled offline engine.",
  "minimum_chrome_version": "116",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage", "sidePanel", "offscreen"],
  "host_permissions": ["https://storage.googleapis.com/bergamot-models-sandbox/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Kotiq Translate",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
