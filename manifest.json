{
  "manifest_version": 3,
  "name": "Select Translate (dev)",
  "version": "0.1.0",
  "description": "Translate selected text on any page, fully on-device with the browser's built-in translator.",
  "minimum_chrome_version": "138",
  "permissions": ["contextMenus", "activeTab", "scripting", "storage", "sidePanel"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Select Translate",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
